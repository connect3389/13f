# 使用方法：复制本文件为 .env 并填写真实信息（.git 已忽略 .env）
#   cp .env.example .env
#
# SEC / EDGAR 要求脚本请求带可识别的 User-Agent（建议：姓名或机构 + 邮箱）
# 说明：https://www.sec.gov/developer

THIRTEENF_SEC_USER_AGENT=Your Name your.email@example.com

# 可选：两次 SEC 请求之间的间隔（秒），默认 0.12
# THIRTEENF_SEC_DELAY=0.12

# 季内行情（Top 10 新建仓）使用 Yahoo Finance，需 uv sync --extra gui（yfinance）
# 可选调试：PRICE_DEBUG=1
